# =============================================================================
# K8s 클러스터 배포 설정 — 환경별로 이 파일만 수정
# =============================================================================

# --- 기본 ---
NAMESPACE="prod"
PROJECT_NAME="doktori"
AWS_REGION="ap-northeast-2"
ECR_REGISTRY="250857930609.dkr.ecr.ap-northeast-2.amazonaws.com"

# --- 모니터링 서버 (외부) ---
MONITORING_SERVER="monitoring.mgmt.doktori.internal"
PROMETHEUS_PORT="9090"
LOKI_PORT="3100"

# --- Helm 차트 버전 (변경 시 호환성 확인) ---
METRICS_SERVER_VERSION="3.12.2"
KUBE_STATE_METRICS_VERSION="5.28.1"
ARGOCD_CHART_VERSION="7.8.13"

# --- 컨테이너 이미지 버전 ---
ALLOY_VERSION="v1.9.0"

# --- HPA ---
HPA_CPU_TARGET=60
HPA_MIN_REPLICAS=2
HPA_MAX_REPLICAS=4

# --- ArgoCD ---
ARGOCD_NODEPORT=31443
# Git 저장소 (ArgoCD Application용)
# GIT_REPO_URL="https://github.com/100-hours-a-week/5-team-doktori-k8s-manifests.git"
# GIT_USERNAME=""
# GIT_PAT=""  # 여기에 직접 쓰지 마세요. setup 스크립트가 프롬프트합니다.