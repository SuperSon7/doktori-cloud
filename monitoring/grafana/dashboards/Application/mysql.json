{
  "uid": "mysql",
  "title": "MySQL / RDS",
  "editable": true,
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(mysql_up, env)",
        "refresh": 1,
        "includeAll": false,
        "current": {
          "text": "prod",
          "value": "prod"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "stat",
      "title": "MySQL Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_up{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_global_status_uptime{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "x": 3,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Current QPS",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{env=\"$env\"}[5m])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Threads Connected",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": ""
        }
      },
      "gridPos": {
        "x": 9,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Threads Running",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_running{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": ""
        }
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Slow Queries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_slow_queries{env=\"$env\"}[5m])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 15,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "gauge",
      "title": "Connection Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{env=\"$env\"} / mysql_global_variables_max_connections{env=\"$env\"} * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "gauge",
      "title": "Buffer Pool Hit Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(1 - rate(mysql_global_status_innodb_buffer_pool_reads{env=\"$env\"}[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests{env=\"$env\"}[5m])) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 21,
        "y": 1,
        "w": 3,
        "h": 4
      }
    },
    {
      "type": "row",
      "title": "Connections",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Connection Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
