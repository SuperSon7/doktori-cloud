{
  "uid": "mysql",
  "title": "MySQL / RDS",
  "editable": true,
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(mysql_up, env)",
        "refresh": 2,
        "includeAll": false,
        "current": {
          "text": "prod",
          "value": "prod"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "mode": "markdown",
        "content": "## Overview"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 2
      },
      "transparent": true
    },
    {
      "id": 2,
      "type": "stat",
      "title": "MySQL Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_up{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 3,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Version",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_version_info{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "gridPos": {
        "x": 3,
        "y": 2,
        "w": 3,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "mysql_global_status_uptime{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "gridPos": {
        "x": 6,
        "y": 2,
        "w": 3,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "QPS",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{env=\"$env\"}[5m])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1
        }
      },
      "gridPos": {
        "x": 9,
        "y": 2,
        "w": 3,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
