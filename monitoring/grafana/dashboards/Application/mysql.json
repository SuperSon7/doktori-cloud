      "title": "BP Hit Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(1-rate(mysql_global_status_innodb_buffer_pool_reads{env=\"$env\"}[5m])/rate(mysql_global_status_innodb_buffer_pool_read_requests{env=\"$env\"}[5m]))*100",
