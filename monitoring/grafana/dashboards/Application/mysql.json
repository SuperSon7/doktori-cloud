          "expr": "mysql_global_status_threads_connected{env=\"$env\"}",
          "legendFormat": "connected",
          "refId": "A"
        },
        {
          "expr": "mysql_global_variables_max_connections{env=\"$env\"}",
          "legendFormat": "max_connections",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 8,
        "h": 8
      }
    },
