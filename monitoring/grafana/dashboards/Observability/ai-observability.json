  "panels": [
    {
      "type": "stat",
      "title": "AI FastAPI Scrape Up",
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up{job=\"prometheus.scrape.ai_fastapi\",app=\"ai\",env=~\"$env\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Request RPS",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (env,instance,status_class) (rate(ai_request_total{env=~\"$env\",instance=~\"$instance\",status_class!=\"5xx\"}[5m]))",
          "legendFormat": "{{env}}/{{instance}} {{status_class}}"
        },
        {
          "refId": "B",
          "expr": "sum by (env,instance) (rate(ai_request_total{env=~\"$env\",instance=~\"$instance\",status_class=\"5xx\"}[5m]))",
          "legendFormat": "{{env}}/{{instance}} 5xx"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* 5xx$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "P95 Request Latency (s)",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le,env,instance) (rate(ai_request_duration_seconds_bucket{env=~\"$env\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{env}}/{{instance}} p95"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
