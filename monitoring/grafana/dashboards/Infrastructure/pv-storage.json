{
  "uid": "pv-storage",
  "title": "PV Storage",
  "tags": ["kubernetes", "storage", "pv"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "prod",
          "value": "prod"
        },
        "hide": 0,
        "label": "Environment",
        "name": "env",
        "options": [
          { "selected": true, "text": "prod", "value": "prod" },
          { "selected": false, "text": "dev", "value": "dev" }
        ],
        "query": "prod,dev",
        "type": "custom"
      },
      {
        "current": {
          "selected": false,
          "text": "prod",
          "value": "prod"
        },
        "hide": 0,
        "label": "Namespace",
        "name": "namespace",
        "options": [
          { "selected": true, "text": "prod", "value": "prod" }
        ],
        "query": "prod",
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "PVC Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Total PVCs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "count(kube_persistentvolumeclaim_info{namespace=\"$namespace\"})",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Bound PVCs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "count(kube_persistentvolumeclaim_status_phase{namespace=\"$namespace\", phase=\"Bound\"}) or vector(0)",
          "legendFormat": "Bound"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "title": "Pending PVCs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "count(kube_persistentvolumeclaim_status_phase{namespace=\"$namespace\", phase=\"Pending\"}) or vector(0)",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Lost PVCs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "count(kube_persistentvolumeclaim_status_phase{namespace=\"$namespace\", phase=\"Lost\"}) or vector(0)",
          "legendFormat": "Lost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 10,
      "title": "Usage",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "title": "PV Usage %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "(\n  kubelet_volume_stats_used_bytes{namespace=\"$namespace\"}\n  /\n  kubelet_volume_stats_capacity_bytes{namespace=\"$namespace\"}\n) * 100",
          "legendFormat": "{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Inode Usage %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "(\n  kubelet_volume_stats_inodes_used{namespace=\"$namespace\"}\n  /\n  kubelet_volume_stats_inodes{namespace=\"$namespace\"}\n) * 100",
          "legendFormat": "{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Disk I/O",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 21,
      "title": "Disk Read Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum by (device) (rate(node_disk_read_bytes_total[5m]))",
          "legendFormat": "{{ device }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 22,
      "title": "Disk Write Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 },
      "targets": [
        {
          "expr": "sum by (device) (rate(node_disk_written_bytes_total[5m]))",
          "legendFormat": "{{ device }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 23,
      "title": "Disk I/O Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 15 },
      "targets": [
        {
          "expr": "rate(node_disk_io_time_seconds_total[5m]) * 100",
          "legendFormat": "{{ device }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
