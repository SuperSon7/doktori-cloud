{
  "uid": "ngf-gateway",
  "title": "Nginx Gateway Fabric",
  "editable": true,
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(nginx_gateway_fabric_nginx_reloads_total, env)",
        "refresh": 1,
        "includeAll": false,
        "current": {
          "text": "prod",
          "value": "prod"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "stat",
      "title": "NGF Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up{job=\"ngf\", env=\"$env\"} == 1)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Config Reloads",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_gateway_fabric_nginx_reloads_total{env=\"$env\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": ""
        }
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Reload Errors",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_gateway_fabric_nginx_reload_errors_total{env=\"$env\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Stale Config",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "nginx_gateway_fabric_nginx_stale_config{env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_connections_active{env=\"$env\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": ""
        }
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total{env=\"$env\"}[5m]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "row",
      "title": "Traffic",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total{env=\"$env\"}[5m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_connections_active{env=\"$env\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "sum(nginx_connections_reading{env=\"$env\"})",
          "legendFormat": "reading",
          "refId": "B"
        },
        {
          "expr": "sum(nginx_connections_writing{env=\"$env\"})",
          "legendFormat": "writing",
          "refId": "C"
        },
        {
          "expr": "sum(nginx_connections_waiting{env=\"$env\"})",
          "legendFormat": "waiting",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Config & Reloads",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Config Reload Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(nginx_gateway_fabric_nginx_reloads_total{env=\"$env\"}[5m])",
          "legendFormat": "reloads",
          "refId": "A"
        },
        {
          "expr": "rate(nginx_gateway_fabric_nginx_reload_errors_total{env=\"$env\"}[5m])",
          "legendFormat": "errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Stale Config",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "nginx_gateway_fabric_nginx_stale_config{env=\"$env\"}",
          "legendFormat": "stale",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Resources (Pod)",
      "collapsed": true,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "NGF CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nginx-gateway\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "NGF Memory Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"nginx-gateway\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      }
    }
  ]
}