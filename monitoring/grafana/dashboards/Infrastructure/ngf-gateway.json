{
  "uid": "ngf-gateway",
  "title": "Nginx Gateway",
  "description": "Nginx 게이트웨이 진입점 모니터링 — 트래픽, 레이턴시, 에러, 커넥션",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["nginx", "gateway", "infrastructure"],
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Env",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(nginx_up{job=\"nginx\"}, env)",
        "refresh": 1,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Nginx 상태",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nginx_up{job=\"nginx\", env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Down", "color": "red", "index": 0 },
                "1": { "text": "Up", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.2",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Active 커넥션",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nginx_connections_active{job=\"nginx\", env=\"$env\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.2",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "요청 속도 (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "irate(nginx_http_requests_total{job=\"nginx\", env=\"$env\"}[5m])",
          "refId": "A",
