{
  "uid": "ngf-gateway",
  "title": "Nginx Gateway Fabric",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(up{job=\"ngf\"}, env)",
        "refresh": 1,
        "includeAll": false,
        "current": {
          "text": "prod",
          "value": "prod"
        }
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{env=\"$env\"}, namespace)",
        "refresh": 1,
        "includeAll": false,
        "current": {
          "text": "nginx-gateway",
          "value": "nginx-gateway"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "NGF Scrape Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up{job=\"ngf\", env=\"$env\"} == 1)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Ready Pods",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kube_pod_status_ready{env=\"$env\", namespace=\"$namespace\", condition=\"true\"} == 1)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Pod Restarts (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{env=\"$env\", namespace=\"$namespace\"}[1h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Config Reloads",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_config_reloads_total{job=\"ngf\", env=\"$env\"}) or sum(nginx_gateway_fabric_nginx_reloads_total{job=\"ngf\", env=\"$env\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_http_connection_count_connections{job=\"ngf\", env=\"$env\"}) or sum(nginx_connections_active{job=\"ngf\", env=\"$env\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total{job=\"ngf\", env=\"$env\"}[5m])) or (sum(nginx_http_request_count_requests{job=\"ngf\", env=\"$env\"}) / 30)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total{job=\"ngf\", env=\"$env\"}[5m])) or (sum(nginx_http_request_count_requests{job=\"ngf\", env=\"$env\"}) / 30)",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Connections",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nginx_http_connection_count_connections{job=\"ngf\", env=\"$env\"}) by (state)",
          "legendFormat": "{{state}}",
          "refId": "A"
        },
        {
          "expr": "sum(nginx_connections_active{job=\"ngf\", env=\"$env\"})",
          "legendFormat": "active",
          "refId": "B"
        },
        {
          "expr": "sum(nginx_connections_reading{job=\"ngf\", env=\"$env\"})",
          "legendFormat": "reading",
          "refId": "C"
        },
        {
          "expr": "sum(nginx_connections_writing{job=\"ngf\", env=\"$env\"})",
          "legendFormat": "writing",
          "refId": "D"
        },
        {
          "expr": "sum(nginx_connections_waiting{job=\"ngf\", env=\"$env\"})",
          "legendFormat": "waiting",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Config & Controller",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Config Reload Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_config_reloads_total{job=\"ngf\", env=\"$env\"}[5m])) or sum(rate(nginx_gateway_fabric_nginx_reloads_total{job=\"ngf\", env=\"$env\"}[5m]))",
          "legendFormat": "reloads/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Event Batch Processing",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_gateway_fabric_event_batch_processing_milliseconds_sum{job=\"ngf\", env=\"$env\"}[5m])) / sum(rate(nginx_gateway_fabric_event_batch_processing_milliseconds_count{job=\"ngf\", env=\"$env\"}[5m]))",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Kubernetes Resources",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "NGF CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{env=\"$env\", namespace=\"$namespace\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "NGF Memory Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{env=\"$env\", namespace=\"$namespace\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Pod Restarts",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{env=\"$env\", namespace=\"$namespace\"}[5m])) by (pod, container)",
          "legendFormat": "{{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Pod Ready",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_pod_status_ready{env=\"$env\", namespace=\"$namespace\", condition=\"true\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "x": 12,
        "y": 35,
        "w": 12,
        "h": 8
      }
    }
  ]
}
