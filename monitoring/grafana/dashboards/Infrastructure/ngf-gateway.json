    {
      "type": "timeseries",
      "id": 21,
      "title": "Request Time p50 / p95 / p99",
      "description": "Nginx request_time 기반 전체 레이턴시. rt - urt 차이가 크면 Nginx 구간 지연",
      "datasource": { "type": "loki", "uid": "loki" },
      "interval": "30s",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.50, {job=\"nginx-access\"} | regexp `rt=(?P<request_time>[\\d.]+)` | unwrap request_time [5m]) by ()",
          "legendFormat": "p50",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {job=\"nginx-access\"} | regexp `rt=(?P<request_time>[\\d.]+)` | unwrap request_time [5m]) by ()",
