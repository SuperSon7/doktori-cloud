      "title": "Container Memory Usage (Working Set)",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "container_memory_working_set_bytes{env=~\"$env\", container=~\"$container\", container!=\"\", pod=~\"$pod\"}",
          "legendFormat": "{{pod}} {{name}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "메모리 사용률 = Working Set / Limit. 100%에 가까우면 OOM Kill 위험.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
