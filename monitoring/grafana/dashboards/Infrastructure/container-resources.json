        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * container_memory_working_set_bytes{env=~\"$env\", container=~\"$container\", container!=\"\", pod=~\"$pod\"} / container_spec_memory_limit_bytes{env=~\"$env\", container=~\"$container\", container!=\"\", pod=~\"$pod\"} > 0",
          "legendFormat": "{{pod}} {{name}}",
          "refId": "A"
        }
