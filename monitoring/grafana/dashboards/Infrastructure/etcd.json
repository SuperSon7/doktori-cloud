{
  "uid": "etcd",
  "title": "etcd Cluster",
  "tags": ["etcd", "kubernetes"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "prod",
          "value": "prod"
        },
        "hide": 0,
        "label": "Environment",
        "name": "env",
        "options": [
          { "selected": true, "text": "prod", "value": "prod" },
          { "selected": false, "text": "dev", "value": "dev" }
        ],
        "query": "prod,dev",
        "type": "custom"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Cluster Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "etcd Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(up{job=~\".*etcd.*\"})",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Leader",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "max(etcd_server_is_leader)",
          "legendFormat": "Has Leader"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No Leader", "color": "red" }, "1": { "text": "Leader OK", "color": "green" } } }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "title": "DB Size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "max(etcd_mvcc_db_total_size_in_bytes)",
          "legendFormat": "DB Size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4294967296 },
              { "color": "red", "value": 6442450944 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Keys Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "max(etcd_debugging_mvcc_keys_total)",
          "legendFormat": "Keys"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 10,
      "title": "Latency",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "title": "WAL fsync p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(etcd_disk_wal_fsync_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Backend commit p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(etcd_disk_backend_commit_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.025 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "gRPC",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "id": 21,
      "title": "gRPC Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_started_total{job=~\".*etcd.*\"}[5m])) by (grpc_method)",
          "legendFormat": "{{ grpc_method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 22,
      "title": "gRPC Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_handled_total{job=~\".*etcd.*\", grpc_code!=\"OK\"}[5m])) by (grpc_method, grpc_code)",
          "legendFormat": "{{ grpc_method }} ({{ grpc_code }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 30,
      "title": "Raft & Elections",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },
    {
      "id": 31,
      "title": "Leader Elections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "increase(etcd_server_leader_changes_seen_total[1h])",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80 },
          "unit": "none",
          "decimals": 0,
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "id": 32,
      "title": "Proposals",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "expr": "rate(etcd_server_proposals_committed_total[5m])",
          "legendFormat": "committed"
        },
        {
          "expr": "rate(etcd_server_proposals_applied_total[5m])",
          "legendFormat": "applied"
        },
        {
          "expr": "rate(etcd_server_proposals_failed_total[5m])",
          "legendFormat": "failed"
        },
        {
          "expr": "etcd_server_proposals_pending",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 33,
      "title": "DB Size (Timeline)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "etcd_mvcc_db_total_size_in_bytes",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "bytes"
        }
      }
    },
    {
      "id": 40,
      "title": "Streams",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },
    {
      "id": 41,
      "title": "Active Streams (Watch / Lease)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "grpc_server_started_total{job=~\".*etcd.*\", grpc_type=\"server_streaming\"} - grpc_server_handled_total{job=~\".*etcd.*\", grpc_type=\"server_streaming\"}",
          "legendFormat": "{{ grpc_method }} ({{ instance }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "none"
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
