      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kubelet_running_containers{env=\"$env\", node=~\"$node\"}",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 4,
