# =============================================================================
# Doktori cloud/local parity .env example
#
# 목적:
# - 클라우드(SSM/Secret)에서 실제로 쓰는 키를 로컬 compose에서도 그대로 검증한다.
# - 로컬만을 위한 별도 키를 만들지 않고, 같은 이름/같은 의미의 변수만 유지한다.
#
# 사용:
# - 로컬 compose: 이 파일을 .env 로 복사한 뒤 값만 실제 값으로 교체
# - 클라우드: 같은 키를 SSM/Secret 에 저장
#
# 메모:
# - 로컬에서만 달라지는 건 "값"이지 "키 이름"이 아니다.
# - API / Chat은 같은 Mongo DB 안에서 컬렉션만 분리한다.
# =============================================================================

# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_URL=jdbc:mysql://mysql:3306/doktoridb?serverTimezone=Asia/Seoul&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change_me_local_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Mongo
# API / Chat 이 같은 Mongo DB 를 사용한다.
# -----------------------------------------------------------------------------
MONGO_USERNAME=doktori
MONGO_PASSWORD=doktori1234
MONGO_URI=mongodb://doktori:doktori1234@mongodb:27017/doktoridb?authSource=admin

# -----------------------------------------------------------------------------
# Kakao OAuth / Book API
# 로컬 검증 시에도 실제 등록값과 동일한 client id/secret 을 넣는다.
# redirect 는 로컬 nginx 기준 예시이며, 클라우드에서는 LB DNS/도메인으로 교체한다.
# -----------------------------------------------------------------------------
KAKAO_CLIENT_ID=change_me
KAKAO_CLIENT_SECRET=change_me
KAKAO_REDIRECT_URI=http://localhost/api/oauth/kakao/callback
KAKAO_FRONTEND_REDIRECT=http://localhost/auth/callback
KAKAO_REST_API_KEY=change_me
KAKAO_BOOK_BASE_URL=https://dapi.kakao.com/v3/search/book

# -----------------------------------------------------------------------------
# Zoom
# ZoomConfig는 startup 시 검증되므로 값이 필요하다
# -----------------------------------------------------------------------------
ZOOM_ACCOUNT_ID=change_me
ZOOM_CLIENT_ID=change_me
ZOOM_CLIENT_SECRET=change_me

# -----------------------------------------------------------------------------
# AI
# AI client bean 생성 시 사용
# 로컬 compose에는 AI 컨테이너를 기본 포함하지 않으므로, 실제 AI를 붙일 때만 base-url 변경
# -----------------------------------------------------------------------------
AI_BASE_URL=http://ai:8000/ai
AI_API_KEY=change_me

# -----------------------------------------------------------------------------
# AWS / S3 / Firebase
# -----------------------------------------------------------------------------
AWS_S3_BUCKET_NAME=doktori-dev-images
AWS_REGION=ap-northeast-2
FIREBASE_SERVICE_ACCOUNT_FILE=./secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=file:/app/secrets/firebase-service-account.json

# -----------------------------------------------------------------------------
# Image-based dev compose only
# docker-compose.dev.yml 에서 사용
# -----------------------------------------------------------------------------
ECR_REGISTRY=250857930609.dkr.ecr.ap-northeast-2.amazonaws.com

# -----------------------------------------------------------------------------
# Monitoring / Alloy helper
# 비워도 compose 파싱은 가능하지만, 필요한 경우 실제 모니터링 서버 IP로 교체
# -----------------------------------------------------------------------------
MONITORING_IP=127.0.0.1
