# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories
**/.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform variable files (may contain secrets)
*.tfvars
*.auto.tfvars
!**/prod-spec.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output
*.plan
*.tfplan
tfplan
tfplan-*
plan.out

# Packer
packer/manifest-*.json

# Local Alloy config overrides (machine-specific)
*.alloy.local

# State backups (local only)
state-backup/
**/state-backup/

# Terraform backend configs (encrypt with SOPS before committing)
**/envs/

# CLI configuration files
.terraformrc
terraform.rc

# =============================================================================
# Credentials & Secrets
# =============================================================================

# GCP service account keys
*.json
!package.json
!package-lock.json
!tsconfig.json
!monitoring/grafana/dashboards/**/*.json

# AWS credentials
*.csv
credentials

# SSH keys
*.pem
*.key
id_rsa*

# Environment files
.env
.env.*
!.env.example

# =============================================================================
# IDE & Editor
# =============================================================================

.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# OS Generated
# =============================================================================

.DS_Store
Thumbs.db

# =============================================================================
# Logs
# =============================================================================

*.log
logs/

# Generated by ansible/generate-inventory.sh
ansible/inventory/


!scripts/
!terraform/**/scripts/
.github/dependabot.yml

# =============================================================================
# Claude Code (local settings & commands)
# =============================================================================
.claude/

# =============================================================================
# Load Test Results
# =============================================================================
load-tests/result/

# =============================================================================
# Service Repos (cloned by make setup, managed independently)
# =============================================================================
/Frontend/
/Backend/
/AI/

# =============================================================================
# Local Docs
# =============================================================================
docs/

# =============================================================================
# Claude Code session artifacts
# =============================================================================
agent.md

# =============================================================================
# MVP Backup (contains credentials)
# =============================================================================
mvp_backup/

# =============================================================================
# Local Exports (contains sensitive values)
# =============================================================================
ssm_params_export.txt
*.params_export.txt
scripts/ssm_inject_dev.sh
scripts/ssm_inject_prod.sh

# =============================================================================
# Lambda build artifacts (archive_file data source가 plan 시 자동 생성)
# =============================================================================
**/lambda/*.zip
