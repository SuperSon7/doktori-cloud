#!/bin/bash
set -euxo pipefail

exec > >(tee -a /var/log/doktori-qdrant-bootstrap.log) 2>&1

export DEBIAN_FRONTEND=noninteractive
export AWS_REGION="${aws_region}"

PARAMETER_PATH="${ssm_parameter_path}"
QDRANT_IMAGE="${qdrant_image}"
QDRANT_ENV_FILE="/opt/qdrant/qdrant.env"
QDRANT_STORAGE_DIR="/opt/qdrant/storage"
QDRANT_RUNNER="/usr/local/bin/run-qdrant.sh"

mkdir -p /opt/qdrant "$QDRANT_STORAGE_DIR"

apt-get update -y
apt-get install -y ca-certificates curl gnupg lsb-release unzip jq

install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list
apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
systemctl enable docker
systemctl start docker

curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip" -o /tmp/awscliv2.zip
unzip -q /tmp/awscliv2.zip -d /tmp
/tmp/aws/install --update
rm -rf /tmp/aws /tmp/awscliv2.zip

QDRANT_API_KEY=$(aws ssm get-parameter \
  --region "$AWS_REGION" \
  --name "$PARAMETER_PATH/QDRANT_API_KEY" \
  --with-decryption \
  --query 'Parameter.Value' \
  --output text)

cat <<EOF > "$QDRANT_ENV_FILE"
QDRANT__SERVICE__HTTP_PORT=6333
QDRANT__SERVICE__GRPC_PORT=6334
QDRANT__SERVICE__HOST=0.0.0.0
QDRANT__SERVICE__API_KEY=$QDRANT_API_KEY
EOF

cat <<'SCRIPT' > "$QDRANT_RUNNER"
#!/bin/bash
set -euxo pipefail

QDRANT_IMAGE="${qdrant_image}"
QDRANT_ENV_FILE="/opt/qdrant/qdrant.env"
QDRANT_STORAGE_DIR="/opt/qdrant/storage"

docker pull "$QDRANT_IMAGE"
docker rm -f dev-ai-qdrant 2>/dev/null || true
docker run -d \
  --name dev-ai-qdrant \
  --restart unless-stopped \
  --env-file "$QDRANT_ENV_FILE" \
  -p 6333:6333 \
  -p 6334:6334 \
  -v "$QDRANT_STORAGE_DIR:/qdrant/storage" \
  "$QDRANT_IMAGE"
SCRIPT

chmod +x "$QDRANT_RUNNER"

cat <<'SERVICE' > /etc/systemd/system/doktori-qdrant.service
[Unit]
Description=Doktori dev Qdrant container
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/run-qdrant.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SERVICE

systemctl daemon-reload
systemctl enable doktori-qdrant.service
systemctl start doktori-qdrant.service
