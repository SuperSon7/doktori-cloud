# -----------------------------------------------------------------------------
# Remote State — 상위 레이어 참조
# -----------------------------------------------------------------------------
data "terraform_remote_state" "base" {
  backend = "s3"
  config = {
    bucket = "doktori-terraform-state"
    key    = "dev/base/terraform.tfstate"
    region = "ap-northeast-2"
  }
}
